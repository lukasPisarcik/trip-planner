# Add your environment variables here.
# Each server var must also be declared in src/lib/server/env.server.ts so it
# gets validated at boot. Never read process.env / Bun.env directly elsewhere.
# `bunx convex dev` writes CONVEX_DEPLOYMENT + PUBLIC_CONVEX_URL into .env.local.

# --- Convex (data layer) ---
# Browser-facing deployment URL for reactive reads (client, via $env/static/public).
# Set automatically by `bunx convex dev`.
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Server-side deployment URL (SSR reads + the AI agent + writes). Same value as
# PUBLIC_CONVEX_URL.
CONVEX_URL=https://your-deployment.convex.cloud

# Owner write-secret. Set the SAME value here AND on the Convex deployment with
# `bunx convex env set OWNER_WRITE_SECRET <value>`. The trusted (local) server
# sends it with every write. DO NOT set this on a public read-only deployment.
OWNER_WRITE_SECRET=replace-with-a-long-random-string

# Set to "true" on a public read-only deployment (e.g. Vercel) to block writes
# and hide the AI co-pilot. Leave unset for local development.
# VIEWER_MODE=true

# --- AI co-pilot ---
# The co-pilot runs through a locally-installed CLI per provider; selecting a
# model in the picker dispatches to that provider. A provider's models show
# disabled until its CLI is signed in (Claude: `claude login`; OpenAI/Codex:
# `codex login`).

# Default Claude model when none is requested. Auth comes from `claude login`.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional override for the `claude` CLI binary path (only set if your
# install isn't on PATH).
# CLAUDE_CODE_PATH=/usr/local/bin/claude

# Default OpenAI/Codex model when none is requested. Auth comes from `codex login`
# (~/.codex/auth.json). Set to a model your installed Codex CLI accepts.
OPENAI_MODEL=gpt-5-codex

# Optional override for the `codex` CLI binary path (only set if your
# install isn't on PATH).
# CODEX_PATH=/usr/local/bin/codex

# Bearer token the Codex agent sends to this app's in-app trip-tools MCP endpoint
# (/api/mcp/trip-planner). The SDK and the route share it so only this server's
# own Codex subprocess can reach the tools. Optional (loopback-only otherwise).
# MCP_BRIDGE_SECRET=replace-with-a-long-random-string
