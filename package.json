{
	"name": "trip-planner",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "bunx --bun vite dev",
		"dev:convex": "bunx convex dev",
		"build": "bunx --bun vite build",
		"preview": "bunx --bun vite preview",
		"prepare": "bunx svelte-kit sync",
		"check": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bunx svelte-kit sync && bunx svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "bunx prettier --write .",
		"lint": "bunx prettier --check . && bunx eslint .",
		"test": "bun run check && bun run lint",
		"changeset": "bunx changeset",
		"changeset:add": "bunx changeset add",
		"changeset:version": "bunx changeset version",
		"changeset:publish": "bunx changeset publish",
		"check:changeset": "bunx changeset status --since=origin/main"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.141",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@openai/codex-sdk": "^0.139.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"convex": "^1.38.0",
		"convex-svelte": "^0.13.0",
		"leaflet": "^1.9.4",
		"marked": "^18.0.3",
		"pino": "^10.3.1",
		"svelte-dnd-action": "^0.9.70",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.14.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/bun": "^1.3.14",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^25.7.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"pino-pretty": "^13.1.3",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"svelte-sonner": "^1.1.1",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.12"
	}
}
